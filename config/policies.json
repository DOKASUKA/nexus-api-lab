{                                                                                                                                  "policies": [
  {                                                                                                                          
    "name": "auth-workers",
    "policyType": "set-headers-inbound",
    "handler": {
      "export": "SetHeadersInboundPolicy",
      "module": "$import(@zuplo/runtime)",
      "options": {
        "headers": [
          {
            "name": "x-nexus-shared-secret",
            "value": "$env(NEXUS_SHARED_SECRET)",
            "overwrite": true
          }
        ]
      }
    }
  }
]
}