{
  "openapi": "3.1.0",
  "info": {
    "title": "Nexus API Gateway",
    "version": "1.0.0"
  },
  "paths": {
    "/hello": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "get": {
        "summary": "Returns a hello message",
        "operationId": "getHello",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "default",
            "module": "$import(./modules/upstreamProxy)",
            "options": {
              "upstreamUrl": "${env.HELLO_API_URL}/hello"
            }
          },
          "policies": {
            "inbound": [],
            "outbound": []
          }
        },
        "responses": {
          "200": { "description": "OK" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/summarize": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "post": {
        "summary": "Summarizes the provided text",
        "operationId": "summarizeText",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "default",
            "module": "$import(./modules/upstreamProxy)",
            "options": {
              "upstreamUrl": "${env.SUMMARIZE_API_URL}/summarize"
            }
          },
          "policies": {
            "inbound": [],
            "outbound": []
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": {
          "200": { "description": "OK" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" },
          "405": { "description": "Method not allowed" }
        }
      }
    },
    "/translate": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "post": {
        "summary": "Translates text to the specified language",
        "operationId": "translateText",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "default",
            "module": "$import(./modules/upstreamProxy)",
            "options": {
              "upstreamUrl": "${env.TRANSLATE_API_URL}/translate"
            }
          },
          "policies": {
            "inbound": [],
            "outbound": []
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": {
          "200": { "description": "OK" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" },
          "405": { "description": "Method not allowed" }
        }
      }
    }
  }
}
