{                                                                                                                                  "openapi": "3.1.0",
"info": {                                                                                                                    
  "title": "Nexus API Gateway",
  "version": "1.0.0"
},
"servers": [
  { "url": "https://api.nexus-api-lab.com" }
],
"paths": {
  "/hello": {
    "x-zuplo-path": { "pathMode": "open-api" },
    "get": {
      "summary": "Returns a hello message",
      "operationId": "getHello",
      "x-zuplo-route": {
        "handler": {
          "export": "urlForwardHandler",
          "module": "$import(@zuplo/runtime)",
          "options": {
            "baseUrl": "https://nexus-hello-api.dokasukadon.workers.dev"
          }
        },
        "policies": {
          "inbound": ["auth-workers"]
        }
      },
      "responses": { "200": { "description": "It is OK." } }
    }
  },
  "/summarize": {
    "x-zuplo-path": { "pathMode": "open-api" },
    "post": {
      "summary": "Summarizes text",
      "operationId": "postSummarize",
      "x-zuplo-route": {
        "handler": {
          "export": "urlForwardHandler",
          "module": "$import(@zuplo/runtime)",
          "options": {
            "baseUrl": "https://nexus-summarize-api.dokasukadon.workers.dev"
          }
        },
        "policies": {
          "inbound": ["auth-workers"]
        }
      },
      "responses": { "200": { "description": "OK" } }
    }
  },
  "/translate": {
    "x-zuplo-path": { "pathMode": "open-api" },
    "post": {
      "summary": "Translates text",
      "operationId": "postTranslate",
      "x-zuplo-route": {
        "handler": {
          "export": "urlForwardHandler",
          "module": "$import(@zuplo/runtime)",
          "options": {
            "baseUrl": "https://nexus-translate-api.dokasukadon.workers.dev"
          }
        },
        "policies": {
          "inbound": ["auth-workers"]
        }
      },
      "responses": { "200": { "description": "OK" } }
    }
  }
}
}