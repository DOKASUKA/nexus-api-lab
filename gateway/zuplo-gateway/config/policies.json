{
  "policies": [
    {
      "name": "auth-workers",
      "policyType": "set-headers-outbound",
      "handler": {
        "export": "SetHeadersOutboundPolicy",
        "module": "$import(@zuplo/runtime)",
        "options": {
          "headers": {
            "X-Nexus-Shared-Secret": "${env.SHARED_SECRET_AUTH}"
          }
        }
      }
    }
  ]
}