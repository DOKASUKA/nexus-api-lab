{
  "policies": [
    {
      "name": "auth-workers",
      "policyType": "set-headers-outbound",
      "handler": {
        "export": "SetHeadersOutboundPolicy",
        "module": "$import(@zuplo/runtime)",
        "options": {
          "headers": [
            {
              "name": "X-Nexus-Shared-Secret",
              "value": "${env.SHARED_SECRET_AUTH}"
            }
          ]
        }
      }
    }
  ]
}