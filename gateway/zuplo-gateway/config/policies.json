{
  "policies": [
    {
      "name": "auth-workers",
      "policyType": "add-request-header",
      "handler": {
        "export": "AddRequestHeaderPolicy",
        "module": "$import(@zuplo/runtime)",
        "options": {
          "header": "X-Shared-Secret",
          "value": "${env.SHARED_SECRET_AUTH}"
        }
      }
    }
  ]
}