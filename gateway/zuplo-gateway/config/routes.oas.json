{
  "openapi": "3.1.0",
  "info": {
    "title": "Nexus API Gateway",
    "version": "1.0.0"
  },
  "paths": {
    "/hello": {
      "x-zuplo-path": { "pathMode": "open-api" },
      "get": {
        "summary": "Returns a hello message",
        "operationId": "getHello",
        "x-zuplo-route": {
          "handler": {
            "module": "$import(@zuplo/runtime).urlForwardHandler",
            "options": {
              "url": "https://nexus-hello-api.あなたのサブドメイン.workers.dev/hello"
            }
          },
          "policies": [
            {
              "name": "auth-workers",
              "handler": {
                "export": "RequestHeaderModifierPolicy",
                "module": "$import(@zuplo/runtime)",
                "options": {
                  "add": { "X-Shared-Secret": "${env.SHARED_SECRET_AUTH}" }
                }
              }
            }
          ]
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/summarize": {
      "x-zuplo-path": { "pathMode": "open-api" },
      "post": {
        "x-zuplo-route": {
          "handler": {
            "module": "$import(@zuplo/runtime).urlForwardHandler",
            "options": {
              "url": "https://nexus-summarize-api.あなたのサブドメイン.workers.dev/summarize"
            }
          },
          "policies": [
            {
              "name": "auth-workers",
              "handler": {
                "export": "RequestHeaderModifierPolicy",
                "module": "$import(@zuplo/runtime)",
                "options": {
                  "add": { "X-Shared-Secret": "${env.SHARED_SECRET_AUTH}" }
                }
              }
            }
          ]
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/translate": {
      "x-zuplo-path": { "pathMode": "open-api" },
      "post": {
        "x-zuplo-route": {
          "handler": {
            "module": "$import(@zuplo/runtime).urlForwardHandler",
            "options": {
              "url": "https://nexus-translate-api.あなたのサブドメイン.workers.dev/translate"
            }
          },
          "policies": [
            {
              "name": "auth-workers",
              "handler": {
                "export": "RequestHeaderModifierPolicy",
                "module": "$import(@zuplo/runtime)",
                "options": {
                  "add": { "X-Shared-Secret": "${env.SHARED_SECRET_AUTH}" }
                }
              }
            }
          ]
        },
        "responses": { "200": { "description": "OK" } }
      }
    }
  }
}