{
  "openapi": "3.1.0",
  "info": {
    "title": "Nexus API Gateway",
    "version": "1.0.0",
    "description": "Unified API Gateway for Nexus API Lab (hello, summarize, translate)"
  },
  "paths": {
    "/hello": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "get": {
        "summary": "Returns a hello message",
        "description": "Simple hello endpoint proxied to nexus-hello-api Cloudflare Worker.",
        "operationId": "getHello",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "forwardTo": "${env.HELLO_API_URL}/hello",
              "followRedirects": false
            }
          },
          "policies": {
            "inbound": ["shared-secret-inbound"],
            "outbound": []
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Hello from Nexus API Lab"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/summarize": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "post": {
        "summary": "Summarizes the provided text",
        "description": "Text summarization endpoint proxied to nexus-summarize-api Cloudflare Worker.",
        "operationId": "summarizeText",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "forwardTo": "${env.SUMMARIZE_API_URL}/summarize",
              "followRedirects": false
            }
          },
          "policies": {
            "inbound": ["shared-secret-inbound"],
            "outbound": []
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": {
                    "type": "string",
                    "example": "This is the text that will be summarized by the API."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "summary": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" },
          "405": { "description": "Method not allowed" }
        }
      }
    },
    "/translate": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "post": {
        "summary": "Translates text to the specified language",
        "description": "Translation endpoint proxied to nexus-translate-api Cloudflare Worker.",
        "operationId": "translateText",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "forwardTo": "${env.TRANSLATE_API_URL}/translate",
              "followRedirects": false
            }
          },
          "policies": {
            "inbound": ["shared-secret-inbound"],
            "outbound": []
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text", "target_language"],
                "properties": {
                  "text": {
                    "type": "string",
                    "example": "hello world"
                  },
                  "target_language": {
                    "type": "string",
                    "example": "ja"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "translated_text": { "type": "string" },
                    "target_language": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" },
          "405": { "description": "Method not allowed" }
        }
      }
    }
  }
}
