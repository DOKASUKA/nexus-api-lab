{
  "policies": [
    {
      "name": "auth-workers",
      "policyType": "set-headers-inbound",
      "handler": {
        "export": "SetHeadersInboundPolicy",
        "module": "$import(@zuplo/runtime)",
        "options": {
          "headers": [
            {
              "name": "X-Shared-Secret",
              "value": "$env(SHARED_SECRET_AUTH)"
            }
          ]
        }
      }
    }
  ]
}
