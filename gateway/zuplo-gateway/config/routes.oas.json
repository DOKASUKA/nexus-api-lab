{
  "openapi": "3.1.0",
  "info": {
    "title": "Nexus API Gateway",
    "version": "1.0.0"
  },
  "paths": {
    "/hello": {
      "x-zuplo-path": { "pathMode": "open-api" },
      "get": {
        "summary": "Returns a hello message",
        "operationId": "getHello",
        "x-zuplo-route": {
          "handler": {
            "export": "urlRewriteHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "rewriteUri": "https://nexus-hello-api.dokasukadon.workers.dev/hello"
            }
          },
          "policies": {
            "inbound": ["auth-workers"],
            "outbound": []
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/summarize": {
      "x-zuplo-path": { "pathMode": "open-api" },
      "post": {
        "x-zuplo-route": {
          "handler": {
            "export": "urlRewriteHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "rewriteUri": "https://nexus-summarize-api.dokasukadon.workers.dev/summarize"
            }
          },
          "policies": {
            "inbound": ["auth-workers"],
            "outbound": []
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/translate": {
      "x-zuplo-path": { "pathMode": "open-api" },
      "post": {
        "x-zuplo-route": {
          "handler": {
            "export": "urlRewriteHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "rewriteUri": "https://nexus-translate-api.dokasukadon.workers.dev/translate"
            }
          },
          "policies": {
            "inbound": ["auth-workers"],
            "outbound": []
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    }
  }
}